{
  "routes": [
    {
      "src": "/api/:path*",
      "dest": "https://deepmind-developers-ai-powered-markdown-t0n2.onrender.com/api/:path*"
    },
    {
      "src": "/poster.html",
      "dest": "/poster.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
